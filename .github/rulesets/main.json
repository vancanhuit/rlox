{
  "name": "main",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": ["~DEFAULT_BRANCH"],
      "exclude": []
    }
  },
  "rules": [
    { "type": "deletion" },
    { "type": "non_fast_forward" },
    { "type": "required_linear_history" },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 0,
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": true,
        "required_reviewers": [],
        "allowed_merge_methods": ["squash"]
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          { "context": "Lint and test",                            "integration_id": 15368 },
          { "context": "Build (x86_64-unknown-linux-gnu)",         "integration_id": 15368 },
          { "context": "Build (aarch64-unknown-linux-gnu)",        "integration_id": 15368 },
          { "context": "Coverage",                                 "integration_id": 15368 },
          { "context": "Audit",                                    "integration_id": 15368 },
          { "context": "Conventional Commits",                     "integration_id": 15368 }
        ]
      }
    }
  ]
}
